        "@google/generative-ai": "^0.24.0",
        "@types/node-schedule": "^2.1.7",
        "deepl-node": "^1.17.3",
        "discord.js": "^14.18.0",
        "dotenv": "^16.5.0",
        "fs-extra": "^11.3.0",
        "fuse.js": "^7.1.0",
        "i18next": "^24.2.3",
        "i18next-fs-backend": "^2.6.0",
        "node-schedule": "^2.1.1",
        "pg": "^8.14.1",
        "sequelize": "^6.37.7",
        "typescript": "^5.8.3"
    },
    "devDependencies": {
        "eslint": "^9.24.0",
        "prettier": "^3.5.3"
    }
