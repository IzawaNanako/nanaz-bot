{
    "compilerOptions": {
        "noEmit": true,
        "isolatedModules": true,
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "nodenext",
        "strict": true,
        "noImplicitAny": true,
        "declaration": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "allowSyntheticDefaultImports": true,
        "paths": {
          "@/*": ["./src/*"],
          "@utils/*": ["./src/utils/*"],
          "@models/*": ["./src/models/*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}
