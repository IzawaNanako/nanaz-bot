{
    "type": "module",
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "noImplicitAny": true,
        "declaration": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "allowSyntheticDefaultImports": true,
        "baseUrl": "./src",
        "outDir": "dist",
        "paths": {
          "*": ["*.js", "*.ts"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}